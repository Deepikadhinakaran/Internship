<script>
/* ═══════════════════════════════════════════════════════════
   THEME TOGGLE — light / dark
═══════════════════════════════════════════════════════════ */
(function() {
  const html = document.documentElement;
  const btn  = document.getElementById('theme-btn');

  // Respect OS preference on first load
  const stored = localStorage.getItem('theme');
  const system = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
  const initial = stored || system;
  applyTheme(initial);

  btn.addEventListener('click', function() {
    const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    applyTheme(next);
    localStorage.setItem('theme', next);
  });

  function applyTheme(t) {
    html.setAttribute('data-theme', t);
    btn.textContent = t === 'dark' ? '☀' : '🌙';
    btn.setAttribute('aria-label', t === 'dark' ? 'Switch to light mode' : 'Switch to dark mode');
  }
})();

/* ═══════════════════════════════════════════════════════════
   SPA NAVIGATION
═══════════════════════════════════════════════════════════ */
const PAGES = ['home','about','projects','contact'];

function navigate(target) {
  if (!PAGES.includes(target)) return;

  PAGES.forEach(p => {
    const pg   = document.getElementById('page-' + p);
    const link = document.getElementById('nav-' + p);
    if (pg)   pg.classList.toggle('active', p === target);
    if (link) {
      if (p === target) link.setAttribute('aria-current','page');
      else link.removeAttribute('aria-current');
    }
  });

  const main = document.getElementById('main-content');
  if (main) main.focus();

  const navList = document.getElementById('primary-nav');
  const toggle  = document.getElementById('nav-toggle');
  if (navList) navList.classList.remove('open');
  if (toggle)  toggle.setAttribute('aria-expanded','false');

  window.location.hash = target === 'home' ? '' : target;
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// Restore page on load
(function() {
  const hash = window.location.hash.replace('#','');
  if (PAGES.includes(hash)) navigate(hash);
})();

// Mobile nav toggle
document.getElementById('nav-toggle').addEventListener('click', function() {
  const nav = document.getElementById('primary-nav');
  const open = this.getAttribute('aria-expanded') === 'true';
  this.setAttribute('aria-expanded', String(!open));
  this.setAttribute('aria-label', !open ? 'Close navigation menu' : 'Open navigation menu');
  nav.classList.toggle('open', !open);
});

// Close on Escape
document.addEventListener('keydown', function(e) {
  if (e.key !== 'Escape') return;
  const nav = document.getElementById('primary-nav');
  nav.classList.remove('open');
  document.getElementById('nav-toggle').setAttribute('aria-expanded','false');
});

/* ═══════════════════════════════════════════════════════════
   CONTACT FORM
═══════════════════════════════════════════════════════════ */
function setFieldError(id, show) {
  const f = document.getElementById(id);
  if (f) f.classList.toggle('has-error', show);
}

function handleSubmit(e) {
  e.preventDefault();
  const form = e.target;
  const name    = form.elements['name'].value.trim();
  const email   = form.elements['email'].value.trim();
  const message = form.elements['message'].value.trim();
  const consent = form.elements['consent'].checked;
  const re      = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  setFieldError('ff-name',    !name);
  setFieldError('ff-email',   !email || !re.test(email));
  setFieldError('ff-message', message.length < 20);

  const cErr = document.getElementById('err-consent');
  cErr.style.display = !consent ? 'block' : 'none';

  const valid = name && email && re.test(email) && message.length >= 20 && consent;

  const statusEl = document.getElementById('form-status-inner');

  if (!valid) {
    statusEl.className = 'form-status error';
    statusEl.textContent = '⚠ Please fix the errors above and try again.';
    statusEl.style.display = 'flex';
    const first = form.querySelector('.has-error input, .has-error textarea') || document.getElementById('c-consent');
    if (first) first.focus();
    return;
  }

  statusEl.className = 'form-status success';
  statusEl.textContent = '✓ Message sent! I\'ll be in touch within 24 hours.';
  statusEl.style.display = 'flex';
  form.reset();
  statusEl.focus();
}

// Live blur validation
['c-name','c-email','c-message'].forEach(id => {
  const el = document.getElementById(id);
  if (!el) return;
  el.addEventListener('blur', function() {
    const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (id === 'c-name')    setFieldError('ff-name',    !this.value.trim());
    if (id === 'c-email')   setFieldError('ff-email',   !this.value.trim() || !re.test(this.value));
    if (id === 'c-message') setFieldError('ff-message', this.value.trim().length < 20);
  });
});

/* ═══════════════════════════════════════════════════════════
   SCROLL REVEAL — IntersectionObserver for skill bars
   (re-triggers animation when section comes into view)
═══════════════════════════════════════════════════════════ */
if ('IntersectionObserver' in window) {
  const obs = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.querySelectorAll('.skill-fill').forEach(bar => {
          bar.style.animation = 'none';
          bar.offsetHeight; // reflow
          bar.style.animation = '';
        });
      }
    });
  }, { threshold: .3 });

  document.querySelectorAll('.skill-list').forEach(el => obs.observe(el));
}
</script>
